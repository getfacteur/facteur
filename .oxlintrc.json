{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "react", "jsx-a11y"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "react/no-children-prop": "off"
  },
  "env": {
    "builtin": true
  },
  "ignorePatterns": ["src/components/ui/**"]
}
